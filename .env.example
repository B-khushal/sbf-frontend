# ============================================
# SBF Florist Frontend — Environment Variables
# ============================================
# For Docker builds, these are passed as BUILD ARGS
# in docker-compose.yml (not read from .env at runtime).
# ============================================

# ── API Configuration ────────────────────────
# Development (local):
VITE_API_URL=http://localhost:5000/api
VITE_UPLOADS_URL=http://localhost:5000

# Docker local testing:
# VITE_API_URL=http://localhost:5000/api
# VITE_UPLOADS_URL=http://localhost:5000

# Production (Dokploy):
# VITE_API_URL=https://api.sbflorist.in/api
# VITE_UPLOADS_URL=https://api.sbflorist.in

# ── App Mode ─────────────────────────────────
NODE_ENV=development
VITE_APP_MODE=development

# ── Google OAuth ─────────────────────────────
# Get from: https://console.cloud.google.com/
# Add your domain to authorized JavaScript origins
VITE_GOOGLE_CLIENT_ID=your-google-client-id-here

# ── Razorpay ─────────────────────────────────
# Test: rzp_test_*  |  Live: rzp_live_*
# Get from: https://dashboard.razorpay.com/
VITE_RAZORPAY_KEY_ID=rzp_test_your_key_id

# ── Firebase (Optional) ─────────────────────
# Only needed if using Firebase services (push notifications)
# Get from: https://console.firebase.google.com/
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=your-app-id

# Frontend Production Environment Variables
# USE THIS FILE FOR PRODUCTION DEPLOYMENT ONLY
# Copy values from here to .env when deploying to production

# API Configuration - Production Domain
VITE_API_URL=https://api.sbflorist.in/api
VITE_UPLOADS_URL=https://api.sbflorist.in

# Production Mode
NODE_ENV=production
VITE_APP_MODE=production

# Google OAuth Configuration (Production)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Razorpay Configuration - LIVE MODE
VITE_RAZORPAY_KEY_ID=rzp_live_YOUR_LIVE_KEY_ID
VITE_RAZORPAY_KEY_SECRET=your_live_key_secret

# Firebase Configuration (Production project)
VITE_FIREBASE_API_KEY=your-production-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Feature Flags for Production
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_PAYMENT=true
VITE_MOCK_PAYMENT=false
VITE_ENABLE_EMAIL=true
VITE_DEV_LOGGING=false

# Analytics IDs (if using)
VITE_GA_TRACKING_ID=G-XXXXXXXXXX
VITE_FB_PIXEL_ID=your-fb-pixel-id
